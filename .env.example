# Postgres (Drizzle / rotas /api/db) — connection string do Supabase (Settings → Database)
DATABASE_URL=

# API Base URL
NEXT_PUBLIC_API_BASE_URL=API_BASE_URL

# Assistant API URL
NEXT_PUBLIC_ASSISTANT_API_URL=ASSISTANT_API_URL

# Softcom Cloud API (somente servidor — nunca use NEXT_PUBLIC_ para a API key)
# Ex.: BASE_URL=https://api.softcom.cloud  (o /v1 é acrescentado automaticamente)
SOFTCOM_CLOUD_BASE_URL=
SOFTCOM_CLOUD_API_KEY=

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
# O assistente do Supabase costuma gerar exatamente estes nomes:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Alternativa clássica (JWT anon), se preferir:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — apenas no servidor (rotas /api/db de anexos). Nunca exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# IDs opacos para endpoints públicos (HMAC-SHA256).
# Defina um segredo longo (>= 32 caracteres). Não compartilhe e não exponha no client.
PUBLIC_OPAQUE_ID_SECRET=

# Discord — notificação DM ao abrir/clonar caso (apenas servidor; rotas /api/projeto-casos).
# Bot precisa estar no servidor da equipe; ative intent "Server Members" no Developer Portal.
DISCORD_BOT_TOKEN=
# ID do servidor (guild) para resolver usuario_discord por username (ex.: luizeduardo9844).
DISCORD_GUILD_ID=
# URL base dos links na DM (opcional; padrão: https://softflow.softcom.services/casos)
CASOS_APP_BASE_URL=https://softflow.softcom.services/casos
